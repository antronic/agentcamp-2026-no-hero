# Azure AI Foundry — required
AZURE_AIPROJECT_ENDPOINT=https://<your-project>.services.ai.azure.com/api/projects/<project-id>
AZURE_AGENT_NAME=<your-agent-name>

# Azure OpenAI (for embeddings) — required
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
AZURE_OPENAI_API_KEY=<your-api-key>

# MongoDB — required
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Azure AI deployment names — optional (defaults shown)
# AZURE_MODEL_DEPLOYMENT=gpt-4o-mini
# AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# MCP server — optional (defaults shown)
# MCP_SERVER_URL=http://localhost:9001/mcp

# MongoDB database name — optional (defaults shown)
# DB_NAME=zstore

# Server — optional (defaults shown)
# PORT=9000
